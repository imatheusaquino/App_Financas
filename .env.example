# Supabase — obtenha em: https://supabase.com/dashboard/project/_/settings/api
# Estas são chaves PÚBLICAS (anon/publishable), seguras para o frontend.
# A segurança dos dados é garantida pelas políticas RLS no Supabase.
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxx

# NUNCA adicione aqui a service_role key do Supabase.
# Se precisar de operações admin (server-only), use:
# SUPABASE_SERVICE_ROLE_KEY=  ← sem prefixo NEXT_PUBLIC_
